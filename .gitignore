# ==============================
# 1. Python 运行时的缓存和编译文件
# ==============================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ==============================
# 2. 虚拟环境（千万别把整个环境传上去）
# ==============================
venv/
env/
.env/
.venv/
conda_env/

# ==============================
# 3. 深度学习模型权重与大数据集
# ==============================
*.pth
*.pt
*.ckpt
*.weights
*.onnx
*.h5
*.pb
datasets/
data/
images/

# ==============================
# 4. 训练日志与可视化输出
# ==============================
logs/
runs/
wandb/
tensorboard/

# ==============================
# 5. IDE 配置文件（比如 VSCode 或 PyCharm 的私有配置）
# ==============================
.vscode/
.idea/
*.swp

# ==============================
# 6. 操作系统生成的垃圾文件
# ==============================
.DS_Store
Thumbs.db